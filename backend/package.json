{
    "name": "@business-saas/api",
    "version": "1.0.0",
    "description": "Local Business Discovery Platform - Backend API",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "prebuild": "rimraf dist tsconfig.tsbuildinfo",
        "build": "npx nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "dev": "node scripts/ensure-port-free.js && npm run start:dev",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main.js",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "migration:generate": "npx ts-node --project tsconfig.json --transpile-only -r tsconfig-paths/register ../node_modules/typeorm/cli.js migration:generate -d src/data-source.ts",
        "migration:run": "npx ts-node --project tsconfig.json --transpile-only -r tsconfig-paths/register ../node_modules/typeorm/cli.js migration:run -d src/data-source.ts",
        "migration:revert": "npx ts-node --project tsconfig.json --transpile-only -r tsconfig-paths/register ../node_modules/typeorm/cli.js migration:revert -d src/data-source.ts",
        "seed": "ts-node src/database/seeds/run-seeds.ts",
        "search:sync": "curl -X POST `${process.env.NEXT_PUBLIC_API_URL}`/search/sync",
        "swagger:generate": "ts-node -r tsconfig-paths/register scripts/generate-swagger.ts"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "@elastic/elasticsearch": "^8.11.0",
        "@google/generative-ai": "^0.24.1",
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/cache-manager": "^3.1.0",
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.1.14",
        "@nestjs/elasticsearch": "^11.0.1",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/platform-socket.io": "^11.1.14",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/serve-static": "^5.0.4",
        "@nestjs/swagger": "^11.2.6",
        "@nestjs/throttler": "^6.4.1",
        "@nestjs/typeorm": "^11.0.0",
        "@nestjs/websockets": "^11.1.14",
        "@types/multer": "^2.0.0",
        "@types/web-push": "^3.6.4",
        "bcrypt": "^5.1.1",
        "bullmq": "^5.77.6",
        "cache-manager": "^7.2.8",
        "cache-manager-redis-yet": "^5.1.5",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "cloudinary": "^1.41.3",
        "compression": "^1.8.1",
        "firebase-admin": "^13.8.0",
        "google-auth-library": "^10.6.1",
        "helmet": "^8.1.0",
        "libphonenumber-js": "^1.13.3",
        "multer-storage-cloudinary": "^4.0.0",
        "nanoid": "^3.3.4",
        "napi-postinstall": "^0.3.0",
        "nodemailer": "^8.0.7",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.18.0",
        "redis": "^4.6.12",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "socket.io": "^4.8.3",
        "streamifier": "^0.1.1",
        "stripe": "^20.4.1",
        "typeorm": "^0.3.28",
        "unrs-resolver": "^1.11.1",
        "uuid": "^9.0.1",
        "web-push": "^3.6.7"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.16",
        "@nestjs/schematics": "^11.0.9",
        "@nestjs/testing": "^11.1.14",
        "@types/bcrypt": "^5.0.2",
        "@types/compression": "^1.8.1",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.11",
        "@types/node": "^20.10.6",
        "@types/nodemailer": "^8.0.0",
        "@types/passport-jwt": "^4.0.1",
        "@types/streamifier": "^0.1.2",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^9.0.7",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.2",
        "jest": "^29.7.0",
        "node-fetch": "^2.6.7",
        "prettier": "^3.1.1",
        "rimraf": "^5.0.5",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.1",
        "ts-loader": "^9.2.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.3.3",
        "yn": "^3.1.1"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
