# Copy to backend/.env and fill in real values

# Database
DATABASE_URL=postgresql://user:password@your-db-host:5432/webapp
DB_SSL=false

# Local fallback (when Postgres runs on this PC)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=local_business_platform

# Public app URLs
FRONTEND_URL=https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- SMTP (OTP / verification emails) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@naampata.com
MAIL_FROM_NAME=NAAMPATA
ADMIN_EMAIL=

# --- Redis Cache ---
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Elasticsearch (optional, for advanced search) ---
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_INDEX=businesses
# ELASTICSEARCH_API_KEY=
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=
# ELASTICSEARCH_REJECT_UNAUTHORIZED=false

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BUSINESS_MONTHLY_PRICE_ID=
STRIPE_BUSINESS_YEARLY_PRICE_ID=

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google categories sync (optional)
GOOGLE_BUSINESS_ACCESS_TOKEN=

# Google Places Autocomplete + geocoding queue
GOOGLE_MAPS_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=

# Seed on startup (dev only)
SEED_DATABASE=false
