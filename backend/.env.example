# Copy to backend/.env and fill in real values

# Database
DATABASE_URL=postgresql://user:password@your-db-host:5432/webapp

# Public app URLs
FRONTEND_URL=https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# --- SMTP (OTP / verification emails) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@naampata.com
MAIL_FROM_NAME=NAAMPATA
ADMIN_EMAIL=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BUSINESS_MONTHLY_PRICE_ID=
STRIPE_BUSINESS_YEARLY_PRICE_ID=

# Google categories sync (optional — Method 2 in docs/SETUP_SMTP_AND_CATEGORIES.md)
GOOGLE_BUSINESS_ACCESS_TOKEN=

# Google Places Autocomplete + geocoding queue (backend proxy — no Maps JS on web)
GOOGLE_MAPS_API_KEY=

# Seed on startup (dev only)
SEED_DATABASE=false
